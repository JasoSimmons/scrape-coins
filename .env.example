# Copy this file to .env and fill in your values.

# Helius API key — sign up free at https://helius.dev (see README for walkthrough).
HELIUS_API_KEY=your-helius-api-key-here

# Optional: override default config.yaml path.
SCRAPE_COINS_CONFIG=config.yaml

# Optional: override default SQLite DB path.
SCRAPE_COINS_DB=coins.db

# Web dashboard
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
